# HERMES Agent Node Stack — ARC-4601
# Brand: #1A1A2E #00D4AA #F5A623 #27AE60 #E74C3C #7F8C8D

direction: down

remote-gw: Remote Gateway (cloud) {
  shape: cloud
  style.font-size: 28
  style.fill: "#27AE60"
  style.font-color: "#1A1A2E"
  style.stroke: "#27AE60"
  style.stroke-width: 3
}

agent-node: Agent Node (local daemon) {
  style.font-size: 28
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 3

  bus-observer: BusObserver {
    shape: hexagon
    style.font-size: 24
    style.fill: "#F5A623"
    style.font-color: "#1A1A2E"
    style.stroke: "#F5A623"
    style.stroke-width: 2

    kqueue: "kqueue / poll" {
      shape: text
      style.font-size: 16
      style.font-color: "#7F8C8D"
      style.italic: true
    }

    offset: "offset-tail" {
      shape: text
      style.font-size: 16
      style.font-color: "#7F8C8D"
      style.italic: true
    }
  }

  gateway-link: GatewayLink {
    shape: hexagon
    style.font-size: 24
    style.fill: "#F5A623"
    style.font-color: "#1A1A2E"
    style.stroke: "#F5A623"
    style.stroke-width: 2

    sse-post: "SSE + POST" {
      shape: text
      style.font-size: 16
      style.font-color: "#7F8C8D"
      style.italic: true
    }

    heartbeat: "heartbeat" {
      shape: text
      style.font-size: 16
      style.font-color: "#7F8C8D"
      style.italic: true
    }
  }

  dispatcher: Dispatcher {
    shape: hexagon
    style.font-size: 24
    style.fill: "#F5A623"
    style.font-color: "#1A1A2E"
    style.stroke: "#F5A623"
    style.stroke-width: 2

    slots: "slots (max 2)" {
      shape: text
      style.font-size: 16
      style.font-color: "#7F8C8D"
      style.italic: true
    }

    guardrails: "guardrails" {
      shape: text
      style.font-size: 16
      style.font-color: "#7F8C8D"
      style.italic: true
    }
  }

  evaluator: MessageEvaluator {
    shape: rectangle
    style.font-size: 24
    style.fill: "#00D4AA"
    style.font-color: "#1A1A2E"
    style.stroke: "#00D4AA"
    style.stroke-width: 3
    style.border-radius: 8
  }

  actions: "dispatch | escalate | forward | ignore" {
    shape: text
    style.font-size: 16
    style.font-color: "#00D4AA"
    style.bold: true
  }

  state-mgr: StateManager {
    shape: rectangle
    style.font-size: 24
    style.fill: "#7F8C8D"
    style.font-color: "#fff"
    style.stroke: "#7F8C8D"
    style.stroke-width: 3
    style.border-radius: 8
  }

  state-detail: "state.json + PID lock" {
    shape: text
    style.font-size: 16
    style.font-color: "#7F8C8D"
    style.italic: true
  }

  # Internal flows

  bus-observer -> evaluator: new messages {
    style.stroke: "#F5A623"
    style.stroke-width: 3
    style.animated: true
    style.font-size: 20
    style.bold: true
  }

  gateway-link -> evaluator: inbound events {
    style.stroke: "#F5A623"
    style.stroke-width: 3
    style.animated: true
    style.font-size: 20
    style.bold: true
  }

  dispatcher -> evaluator: slot status {
    style.stroke: "#F5A623"
    style.stroke-width: 2
    style.stroke-dash: 5
    style.font-size: 20
  }

  evaluator -> actions: {
    style.stroke: "#00D4AA"
    style.stroke-width: 2
    style.stroke-dash: 3
  }

  state-mgr -> state-detail: {
    style.stroke: "#7F8C8D"
    style.stroke-width: 1
    style.stroke-dash: 3
  }
}

bus: bus.jsonl {
  shape: cylinder
  style.font-size: 28
  style.fill: "#1A1A2E"
  style.font-color: "#27AE60"
  style.stroke: "#27AE60"
  style.stroke-width: 3
}

# External connections

remote-gw -> agent-node.gateway-link: SSE /events {
  style.stroke: "#27AE60"
  style.stroke-width: 4
  style.animated: true
  style.font-size: 20
  style.bold: true
}

agent-node.gateway-link -> remote-gw: HTTP POST {
  style.stroke: "#00D4AA"
  style.stroke-width: 4
  style.animated: true
  style.font-size: 20
  style.bold: true
}

agent-node.state-mgr -> bus: read / write {
  style.stroke: "#7F8C8D"
  style.stroke-width: 3
  style.animated: true
  style.font-size: 20
}

agent-node.bus-observer -> bus: kqueue watch {
  style.stroke: "#F5A623"
  style.stroke-width: 3
  style.animated: true
  style.font-size: 20
  style.bold: true
}
