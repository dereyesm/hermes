# HERMES Adapter Bridge — Agent-Agnostic Architecture
# Brand: #1A1A2E #00D4AA #F5A623 #27AE60 #E74C3C #7F8C8D

direction: right

# --- Canonical Source ---

hermes-dir: ~/.hermes/ (canonical) {
  style.font-size: 28
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 3

  config: config.toml {
    shape: document
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#F5A623"
    style.stroke: "#F5A623"
    style.stroke-width: 2
  }

  bus: bus.jsonl {
    shape: cylinder
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#27AE60"
    style.stroke: "#27AE60"
    style.stroke-width: 2
  }

  skills: skills/ {
    shape: document
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#F5A623"
    style.stroke: "#F5A623"
    style.stroke-width: 2
  }

  rules: rules/ {
    shape: document
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#F5A623"
    style.stroke: "#F5A623"
    style.stroke-width: 2
  }

  keys: keys/ {
    shape: document
    style.font-size: 20
    style.fill: "#E74C3C"
    style.font-color: "#fff"
    style.stroke: "#E74C3C"
    style.stroke-width: 2
  }
}

# --- Adapter Pattern ---

adapter: AdapterBase (ABC) {
  shape: hexagon
  style.font-size: 24
  style.fill: "#F5A623"
  style.font-color: "#1A1A2E"
  style.stroke: "#F5A623"
  style.stroke-width: 3

  method: "adapt() -> AdaptResult" {
    shape: text
    style.font-size: 16
    style.font-color: "#1A1A2E"
    style.italic: true
  }
}

# --- Output Targets ---

claude-code: ClaudeCodeAdapter {
  style.font-size: 24
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 3

  strategy: "symlinks (single source of truth)" {
    shape: text
    style.font-size: 16
    style.font-color: "#7F8C8D"
    style.italic: true
  }

  target: ~/.claude/ {
    shape: document
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#00D4AA"
    style.stroke: "#00D4AA"
    style.stroke-width: 2
  }
}

cursor: CursorAdapter {
  style.font-size: 24
  style.fill: "#1A1A2E"
  style.font-color: "#27AE60"
  style.stroke: "#27AE60"
  style.stroke-width: 3

  strategy: "compiled .cursorrules (single file)" {
    shape: text
    style.font-size: 16
    style.font-color: "#7F8C8D"
    style.italic: true
  }

  target: .cursorrules {
    shape: document
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#27AE60"
    style.stroke: "#27AE60"
    style.stroke-width: 2
  }

  markers: "HERMES:BEGIN / HERMES:END" {
    shape: text
    style.font-size: 16
    style.font-color: "#7F8C8D"
    style.italic: true
  }
}

future: Future Adapters {
  shape: cloud
  style.font-size: 24
  style.fill: "#7F8C8D"
  style.font-color: "#fff"
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
}

# --- Connections ---

hermes-dir -> adapter: read canonical {
  style.stroke: "#00D4AA"
  style.stroke-width: 4
  style.animated: true
  style.font-size: 20
  style.bold: true
}

adapter -> claude-code: hermes adapt claude-code {
  style.stroke: "#00D4AA"
  style.stroke-width: 3
  style.animated: true
  style.font-size: 18
  style.bold: true
}

adapter -> cursor: hermes adapt cursor {
  style.stroke: "#27AE60"
  style.stroke-width: 3
  style.animated: true
  style.font-size: 18
  style.bold: true
}

adapter -> future: hermes adapt <agent> {
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 18
}
