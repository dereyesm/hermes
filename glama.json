{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "name": "amaru-bus",
  "description": "Inter-agent communication protocol — bus messaging, crypto, federation, session lifecycle. Amaru protocol.",
  "version": "0.5.0a1",
  "tools": [
    "amaru_bus_read", "amaru_bus_write", "amaru_bus_ack",
    "amaru_syn", "amaru_fin",
    "amaru_status", "amaru_peers",
    "amaru_seal", "amaru_open",
    "amaru_integrity_check", "amaru_hub_send"
  ],
  "resources": [
    "amaru://protocol/version",
    "amaru://bus/stats",
    "amaru://config/clan"
  ],
  "transport": ["stdio"],
  "maintainers": [{"github": "dereyesm"}],
  "repository": "https://github.com/dereyesm/amaru-protocol"
}
