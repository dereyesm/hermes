<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- HERMES Hub Server — ARC-4601 §15 -->
    <!-- WebSocket server that routes messages between clan peers -->
    <!-- Docs: https://github.com/dereyesm/amaru/blob/main/docs/hub-operations.md -->

    <key>Label</key>
    <string>com.amaru.hub</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Replace with your Python path and clan directory -->
        <string>/path/to/python</string>
        <string>-m</string>
        <string>amaru.cli</string>
        <string>hub</string>
        <string>start</string>
        <string>--foreground</string>
        <string>--dir</string>
        <string>/path/to/clan</string>
    </array>

    <!-- Auto-start on login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart on crash -->
    <key>KeepAlive</key>
    <true/>

    <!-- Wait 10s before restart to avoid rapid cycling -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Low priority background process -->
    <key>ProcessType</key>
    <string>Background</string>

    <!-- Logging -->
    <key>StandardOutPath</key>
    <string>/path/to/clan/hub.log</string>

    <key>StandardErrorPath</key>
    <string>/path/to/clan/hub.err</string>
</dict>
</plist>
